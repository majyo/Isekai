# Godot editor/import cache
.godot/
.import/

# Godot export/build output
/android/
/build/
/builds/
/dist/
/export/
/exports/
*.apk
*.aab
*.ipa
*.pck

# C#/.NET build artifacts
bin/
obj/
.mono/
*.user
*.suo
*.userprefs

# Local IDE/editor state
.idea/
.vscode/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs and temporary files
*.log
*.tmp
*.temp

# Generated world-map outputs; keep the folder itself.
/world/generated/*
!/world/generated/.gitkeep

# Generated Terrain3D outputs; keep the folder structure.
/world/terrain/generated/*
!/world/terrain/generated/.gitkeep
!/world/terrain/generated/terrain3d_data/
!/world/terrain/generated/terrain3d_data/.gitkeep
!/world/terrain/generated/reports/
!/world/terrain/generated/reports/.gitkeep

# Terrain3D example project assets are not used by this game.
/demo/
